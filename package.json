{
  "name": "nova-ai",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev",
    "start": "eve start",
    "typecheck": "tsc",
    "test:isolation": "npx --yes tsx evals/isolation/run.ts",
    "test:memory": "npx --yes tsx evals/memory/run.ts",
    "test:jobs": "npx --yes tsx evals/jobs/run.ts",
    "test:spine": "npx --yes tsx evals/spine/run.ts",
    "test:duties": "npx --yes tsx evals/duties/run.ts",
    "test:decisions": "npx --yes tsx evals/decisions/run.ts",
    "test:authority": "npx --yes tsx evals/authority/run.ts",
    "test:night": "npx --yes tsx evals/night/run.ts",
    "test:voice": "npx --yes tsx evals/voice/run.ts",
    "check:duty-seed": "npx --yes tsx scripts/check-duty-seed-sync.ts",
    "check:undo": "npx --yes tsx scripts/check-undo-coverage.ts",
    "test": "npm run typecheck && npm run check:undo && npm run check:duty-seed && npm run test:isolation && npm run test:memory && npm run test:jobs && npm run test:spine && npm run test:duties && npm run test:authority && npm run test:decisions && npm run test:night && npm run test:voice && npm run test:generate && npm run test:conversation && npm run test:reach && npm run test:research",
    "test:generate": "npx --yes tsx evals/generate/run.ts",
    "test:conversation": "npx --yes tsx evals/conversation/run.ts",
    "test:reach": "npx --yes tsx evals/reach/run.ts",
    "test:research": "npx --yes tsx evals/research/run.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@vercel/connect": "0.4.0",
    "ai": "^7.0.26",
    "eve": "^0.25.2",
    "just-bash": "^3.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "typescript": "7.0.2"
  },
  "overrides": {
    "ai": "^7.0.26"
  },
  "engines": {
    "node": "24.x"
  }
}
