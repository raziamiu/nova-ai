{
  "name": "nova-ai",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev",
    "start": "eve start",
    "typecheck": "tsc",
    "test:isolation": "npx --yes tsx evals/isolation/run.ts",
    "test:memory": "npx --yes tsx evals/memory/run.ts",
    "test:jobs": "npx --yes tsx evals/jobs/run.ts",
    "test": "npm run typecheck && npm run test:isolation && npm run test:memory && npm run test:jobs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@vercel/connect": "0.4.0",
    "ai": "^7.0.26",
    "eve": "^0.25.2",
    "just-bash": "^3.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "typescript": "7.0.2"
  },
  "overrides": {
    "ai": "^7.0.26"
  },
  "engines": {
    "node": "24.x"
  }
}
